<!DOCTYPE html>
<html>
  <head>
    <title>ManimaniSanpo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# 💡 アセットパイプラインを通さず、CDNから直接Turboを読み込みます %>
    <script src="https://unpkg.com/@hotwired/turbo@7.3.0/dist/turbo.es2017-umd.js"></script>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <%# --- アイコンを表示するために追加 --- %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  </head>

  <%# 💡 レイヤー1：ベースのグラデーション %>
  <div class="fixed inset-0 z-[-2] pointer-events-none" 
       style="background: radial-gradient(circle at 10% 10%, rgba(255, 255, 255, 0.5), transparent 30%),
                   linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%);">
  </div>

  <%# 💡 レイヤー2：麻の葉模様（ここを大きく見せる！） %>
  <div class="fixed inset-0 z-[-1] pointer-events-none" 
       style="background-image: url('<%= asset_path('麻の葉.png') %>');
              background-size: 650px; <%# 💡 400pxから650pxへ拡大。ここを大きくすると柄が太く・大きくなります %>
              background-repeat: repeat;
              background-position: center; <%# 💡 中心から広がるように配置 %>
              opacity: 0.12; <%# 💡 大きくした分、少しだけ薄くすると高級感が出ます %>
              mix-blend-mode: multiply;">
  </div>
    
    <%# --- ヘッダー（ログイン前） --- %>
    <% unless content_for?(:no_nav) %>
      <% unless user_signed_in? %>
        <header class="fixed top-0 left-0 w-full flex justify-between items-center p-6 z-50 bg-transparent">
          <%= link_to root_path, class: "transition-transform hover:scale-105 active:scale-95" do %> 
            <div class="bg-white rounded-full w-10 h-10 flex items-center justify-center shadow-sm text-gray-400 font-bold text-xs">ロゴ</div>
          <% end %>
          <%= link_to "ログイン", new_user_session_path, 
              class: "px-6 py-2.5 text-white font-bold text-lg rounded-full transition-all hover:opacity-90 hover:shadow-lg shadow-md inline-block text-center",
              style: "background-color: #65C7A4;" %>
        </header>
      <% end %>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <%# --- ログイン後、かつ no_nav が指定されていないページでボトムナビを表示 --- %>
    <% if user_signed_in? && !content_for?(:no_nav) %>
      <%= render 'layouts/bottom_nav' %>
    <% end %>

    <%# 💡 モーダル用の受け皿 %>
    <%= turbo_frame_tag "modal" %>

    <%# --- SweetAlert2 のスクリプト --- %>
    <% if flash[:sent_modal] %>
      <script>
        function showSentModal() {
          Swal.fire({
            title: 'メールを送信しました！',
            html: 'パスワード再設定用のメールを送信しました。<br>メールに記載のURLからパスワードの再設定を行ってください。',
            icon: 'success',
            confirmButtonText: 'OK',
            buttonsStyling: false,
            didOpen: () => {
              const popup = Swal.getPopup();
              popup.style.borderRadius = '3rem';
              const confirmButton = Swal.getConfirmButton();
              confirmButton.style.backgroundColor = '#65C7A4';
              confirmButton.style.color = '#ffffff';
              confirmButton.style.borderRadius = '9999px';
              confirmButton.style.padding = '12px 60px';
              confirmButton.style.fontWeight = 'bold';
              confirmButton.style.border = 'none';
            }
          });
        }
        document.addEventListener("turbo:load", showSentModal);
      </script>
    <% end %>
  </body>
</html>