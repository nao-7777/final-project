<!DOCTYPE html>
<html lang="ja" style="height: 100dvh; margin: 0; padding: 0; background-color: #F5F5F0;">
  <head>
    <title>ManimaniSanpo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#F5F5F0">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# 外部ライブラリ %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <%# TurboはRails標準のものと競合しないよう注意 %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body style="margin: 0; padding: 0; width: 100%; height: 100dvh; overflow: hidden; touch-action: none; background: transparent;">

    <%# --- 背景レイヤー --- %>
    <div style="position: fixed; top: -100px; left: 0; width: 100vw; height: calc(100dvh + 200px); z-index: -2; background: linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%) no-repeat;"></div>
    <div style="position: fixed; top: -100px; left: 0; width: 100vw; height: calc(100dvh + 200px); z-index: -1; pointer-events: none; background-image: url('<%= asset_path('asanoha.png') %>'); background-size: 650px auto; opacity: 0.4;"></div>

    <%# --- ログイン前のみ表示する共通ヘッダー --- %>
    <% unless user_signed_in? || content_for?(:no_nav) %>
      <header class="fixed top-0 left-0 w-full flex justify-between items-center p-6 z-50 bg-transparent">
        <%= link_to root_path, class: "transition-transform hover:scale-105 active:scale-95" do %> 
          <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center shadow-md overflow-hidden">
            <%= image_tag "logomark.png", class: "w-full h-full object-contain" %>
          </div>
        <% end %>
        <%= link_to "ログイン", new_user_session_path, class: "px-6 py-2.5 text-white font-bold text-lg rounded-full shadow-md", style: "background-color: #65C7A4;" %>
      </header>
    <% end %>

    <%# メインコンテンツ：お散歩画面のヘッダーは yield 側（本体）で描写される %>
    <main style="position: relative; z-index: 1; height: 100%; width: 100%;">
      <%= yield %>
    </main>

    <% if user_signed_in? && !content_for?(:no_nav) %>
      <%= render 'layouts/bottom_nav' %>
    <% end %>

    <%= turbo_frame_tag "modal" %>
  </body>
</html>