<!DOCTYPE html>
<html lang="ja" style="height: 100dvh; margin: 0; padding: 0; background-color: #F5F5F0;">
  <head>
    <title>ManimaniSanpo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#F5F5F0" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#F5F5F0" media="(prefers-color-scheme: dark)">

    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/@hotwired/turbo@7.3.0/dist/turbo.es2017-umd.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body style="margin: 0; padding: 0; width: 100%; height: 100dvh; overflow: hidden; touch-action: none; background: transparent;">

    <%# --- 【最背面】グラデーション壁 --- %>
    <div style="position: fixed; top: -100px; left: 0; width: 100vw; height: calc(100dvh + 200px); 
                z-index: -2; 
                background: linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%) no-repeat;
                background-size: 100% 100%;">
    </div>

    <%# --- 【背面】麻の葉レイヤー --- %>
    <div style="position: fixed; top: -100px; left: 0; width: 100vw; height: calc(100dvh + 200px); 
                z-index: -1; pointer-events: none;
                background-image: url('<%= asset_path('asanoha.png') %>');
                background-size: 650px auto;
                background-repeat: repeat;
                opacity: 0.4;
                image-rendering: -webkit-optimize-contrast;">
    </div>

    <%# --- ヘッダー --- %>
    <% unless content_for?(:no_nav) %>
      <% unless user_signed_in? %>
        <header class="fixed top-0 left-0 w-full flex justify-between items-center p-6 z-50 bg-transparent">
          <%= link_to root_path, class: "transition-transform hover:scale-105 active:scale-95" do %> 
            <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center shadow-md overflow-hidden">
              <%= image_tag "logomark.png", class: "w-full h-full object-contain" %>
            </div>
          <% end %>
          <%= link_to "ログイン", new_user_session_path, 
              class: "px-6 py-2.5 text-white font-bold text-lg rounded-full shadow-md inline-block text-center",
              style: "background-color: #65C7A4;" %>
        </header>
      <% end %>
    <% end %>

    <%# メインコンテンツ %>
    <main style="position: relative; z-index: 1; height: 100%; width: 100%;">
      <%= yield %>
    </main>

    <% if user_signed_in? && !content_for?(:no_nav) %>
      <%= render 'layouts/bottom_nav' %>
    <% end %>

    <%= turbo_frame_tag "modal" %>

    <% if flash[:sent_modal] %>
      <script>
        const showSentModal = () => {
          Swal.fire({
            title: 'メールを送信しました！',
            html: 'パスワード再設定用のメールを送信しました。',
            icon: 'success',
            confirmButtonText: 'OK',
            buttonsStyling: false,
            didOpen: () => {
              const btn = Swal.getConfirmButton();
              btn.style.cssText = "background-color:#65C7A4; color:#fff; border-radius:9999px; padding:12px 60px; font-weight:bold; border:none;";
            }
          });
          document.removeEventListener("turbo:load", showSentModal);
        };
        document.addEventListener("turbo:load", showSentModal);
      </script>
      <% flash.delete(:sent_modal) %>
    <% end %>
  </body>
</html>