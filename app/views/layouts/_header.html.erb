<%# app/views/layouts/_header.html.erb %>
<% active_char = current_user.user_characters.includes(:character).first %>

<% if active_char %>
  <% current_lv = active_char.level %>
  <% current_exp = active_char.exp %>
  <%# 次のレベルまでの必要経験値を計算（モデルの重いメソッドを避けるため直接計算） %>
  <% current_limit = current_lv * 500 %>
  <% percent = (current_exp.to_f / current_limit * 100).clamp(0, 100) %>
  <% char_name = active_char.character.name %>
<% else %>
  <% current_lv = 1 %>
  <% percent = 0 %>
  <% char_name = "フォックス" %>
<% end %>

<div class="flex flex-col gap-2.5 p-5 font-sans select-none">
  <div class="flex items-center gap-3">
    <%# --- LEVELの丸 --- %>
    <div class="w-[60px] h-[60px] bg-[#65C7A4] text-white flex flex-col items-center justify-center rounded-full shadow-sm p-4 border-b-4 border-[#54a88a] shrink-0 relative overflow-hidden">
      <div class="absolute top-1 left-2 w-8 h-4 bg-white/20 rounded-full blur-[1px] -rotate-15"></div>
      
      <span class="text-[9px] font-black leading-none mb-0.5 tracking-tighter opacity-90">LEVEL</span>
      <span class="text-2xl font-black leading-none drop-shadow-sm">
        <%= current_lv %>
      </span>
    </div>
    
    <%# --- キャラクターの名前 --- %>
    <div class="mb-1">
      <span class="text-[#4C6496] font-black text-xl tracking-tighter italic">
        <%= char_name %> 
      </span>
    </div>
  </div>
  
  <%# --- 経験値バー --- %>
  <div class="relative -mt-1">
    <div class="w-48 h-3 bg-white/60 rounded-full overflow-hidden border-2 border-white shadow-sm relative">
      <div class="bg-gradient-to-r from-[#65C7A4] to-[#AEEAD3] h-full rounded-full shadow-inner transition-all duration-500" 
           style="width: <%= percent %>%;">
      </div>
    </div>
  </div>

  <%# --- 親愛度（現在は非表示。デザイン保持のためコメントアウト） --- %>
  <%#
  <div class="relative mt-0.5">
    <div class="bg-white/95 backdrop-blur-md px-4 py-1.5 rounded-full shadow-md border border-white w-fit flex items-center gap-2">
      <span class="text-[#F18499] text-sm font-black">親愛度</span>
      <span class="text-[#F18499] text-sm tracking-[0.2em] font-bold">★☆☆☆☆</span>
    </div>
  </div>
  %>
</div>