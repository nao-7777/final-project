<%# 💡 ナビ非表示のフラグ %>
<% content_for(:hide_bottom_nav, true) %>

<div class="char-detail-fullpage">
  <div class="char-bg-pattern"></div>
  
  <%= link_to characters_path, class: "close-btn" do %>
    <i class="bi bi-x-lg"></i>
  <% end %>

  <div class="char-container">
    <div class="char-header">
      <span class="char-no">No.<%= sprintf("%03d", Character.where("id <= ?", @character.id).count) %></span>
      <h1 class="char-name"><%= @character.name %></h1>
    </div>

    <div class="char-main-card">
      <div class="card-scroll-wrapper" id="cardWrapper">
        <%# 進化前 %>
        <div class="card-item">
          <div class="img-wrapper">
            <%= image_tag @character.image_v1, class: "char-img" %>
          </div>
        </div>
        <%# 進化後 %>
        <div class="card-item">
          <div class="img-wrapper evolution-img-container">
            <%= image_tag @character.image_v2, class: "char-img v2-img bust-up-mode", id: "v2Image" %>
            <button class="toggle-view-btn" id="viewToggleBtn">
              <i class="bi bi-arrows-angle-expand"></i> 全身を見る
            </button>
          </div>
        </div>
      </div>
      
      <div class="dots" id="dotContainer">
        <span class="dot active"></span>
        <span class="dot"></span>
      </div>
    </div>

    <%# 💡 このユーザーが持っている「このキャラクター」の成長データを取得 %>
    <% user_char = current_user.user_characters.find_by(character_id: @character.id) %>
    <%# 💡 データがない場合のフォールバック（初期値） %>
    <% current_lv = user_char&.level || 1 %>
    <% current_exp = user_char&.exp || 0 %>
    <% next_cap = current_lv * 500 %>
    <% progress = (current_exp.to_f / next_cap * 100).clamp(0, 100) %>

    <div class="status-panel">
      <div class="st-left">
        <%# 💡 Lvを表示 %>
        <div class="lv-box">Lv.<span><%= current_lv %></span></div>
        <div class="exp-box" style="flex: 1; max-width: 150px;">
          <div class="exp-info">
            <%# 💡 経験値を表示 %>
            <span style="color: #ffffff !important; font-size: 10px; font-weight: 800;">EXP <%= current_exp %> / <%= next_cap %></span>
          </div>
          <div class="exp-bar-bg" style="background-color: rgba(255, 255, 255, 0.8) !important; height: 8px; border-radius: 4px; overflow: hidden; width: 100%;">
            <%# 💡 計算したprogressでゲージの幅を動かす %>
           <div class="exp-fill" style="width: <%= progress %>%; height: 100%; background-color: #65C7A4 !important;"></div>
          </div>
        </div>
      </div>
      <div class="st-right">
        <div class="love-label" style="color: #ffffff !important; font-size: 10px; font-weight: bold; margin-bottom: 3px; text-align: right;">親愛度</div>
        <div class="stars">
          <i class="bi bi-star-fill active"></i><i class="bi bi-star"></i><i class="bi bi-star"></i><i class="bi bi-star"></i><i class="bi bi-star"></i>
        </div>
      </div>
    </div>

    <div class="description-panel">
      <p class="intro-text"><%= @character.description %></p>
    </div>
  </div>
</div>

<style>
nav, .bottom-nav, #bottom-navigation, footer, .fixed-bottom { display: none !important; }

.char-detail-fullpage {
  position: fixed; inset: 0; width: 100vw; height: 100vh; z-index: 99999;
  background: radial-gradient(circle at 10% 10%, rgba(255, 255, 255, 0.5), transparent 30%),
              linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%);
  display: flex; flex-direction: column; padding: 30px 24px; box-sizing: border-box; overflow: hidden;
}

.char-bg-pattern {
  position: absolute; inset: 0; z-index: -1;
  background-image: url('<%= asset_path('麻の葉.png') %>');
  background-size: 650px; opacity: 0.12; mix-blend-mode: multiply;
}

.char-container { width: 100%; max-width: 420px; height: 100%; margin: 0 auto; display: flex; flex-direction: column; gap: 15px; }

.close-btn {
  position: absolute; top: 30px; right: 24px; width: 42px; height: 42px; background: white;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1); z-index: 100; color: #333; text-decoration: none;
}

.char-header { display: flex; align-items: center; gap: 10px; padding-top: 10px; }
.char-no { background: #38423B; color: #fff; font-size: 10px; padding: 3px 10px; border-radius: 4px; font-weight: bold; }
.char-name { font-size: 1.8rem; font-weight: 900; margin: 0; color: #333; }

.char-main-card {
  background: white; border-radius: 28px; padding: 20px; box-shadow: 0 12px 40px rgba(0,0,0,0.06);
  flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 0; overflow: hidden;
}

.card-scroll-wrapper {
  display: flex; width: 100%; height: 100%; overflow-x: auto;
  scroll-snap-type: x mandatory; scroll-behavior: smooth; scrollbar-width: none;
}
.card-scroll-wrapper::-webkit-scrollbar { display: none; }
.card-item { min-width: 100%; height: 100%; scroll-snap-align: center; display: flex; align-items: center; justify-content: center; }

.img-wrapper { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; }
.evolution-img-container { overflow: hidden; width: 100%; height: 100%; }

.char-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: center center; 
}

/* バストアップ設定： */
.bust-up-mode {
  /* scale: 拡大率 / translateY: 上下位置(マイナスで上、プラスで下) */
  transform: scale(4) translateY(35%); 
}

.toggle-view-btn {
  position: absolute; bottom: 0; right: 0; background: rgba(56, 66, 59, 0.7);
  color: white; border: none; padding: 8px 14px; border-radius: 12px 0 0 0; font-size: 11px;
  backdrop-filter: blur(4px); z-index: 10;
}

.dots { margin-top: 15px; display: flex; gap: 10px; }
.dot { width: 9px; height: 9px; background: rgba(101, 199, 164, 0.2); border-radius: 50%; transition: 0.3s; }
.dot.active { background: #65C7A4; transform: scale(1.2); }

.status-panel {
  background: rgba(94, 104, 97, 0.95); border-radius: 22px; padding: 15px 24px;
  display: flex; justify-content: space-between; align-items: center; color: #fff; flex-shrink: 0;
}
.st-left { display: flex; align-items: center; gap: 20px; flex-grow: 1; }
.lv-box span { font-size: 28px; font-weight: 900; display: block; line-height: 1; }
.stars { font-size: 14px; margin-top: 5px; color: rgba(255,255,255,0.3); }
.stars i.active { color: #EE8095; }

.description-panel {
  background: rgba(235, 230, 215, 0.7); padding: 20px 24px; border-radius: 22px;
  max-height: 150px; overflow-y: auto; flex-shrink: 0;
}
.intro-text { font-size: 0.92rem; line-height: 1.7; color: #444; margin: 0; }
</style>

<script>
document.addEventListener('turbo:load', () => {
  const wrapper = document.getElementById('cardWrapper');
  const dots = document.querySelectorAll('#dotContainer .dot');
  const toggleBtn = document.getElementById('viewToggleBtn');
  const v2Image = document.getElementById('v2Image');

  if (wrapper) {
    wrapper.addEventListener('scroll', () => {
      const index = Math.round(wrapper.scrollLeft / wrapper.clientWidth);
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
    });
  }

  if (toggleBtn && v2Image) {
    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const isBustUp = v2Image.classList.contains('bust-up-mode');
      if (isBustUp) {
        v2Image.classList.remove('bust-up-mode');
        toggleBtn.innerHTML = '<i class="bi bi-arrows-angle-expand"></i> 全身を見る';
      } else {
        v2Image.classList.add('bust-up-mode');
        toggleBtn.innerHTML = '<i class="bi bi-arrows-angle-contract"></i> 顔を見る';
      }
    });
  }
});
</script>