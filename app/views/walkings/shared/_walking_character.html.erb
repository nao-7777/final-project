<%# --- 1. 判定ロジック --- %>
<% active_char = current_user.user_characters.first %>
<% current_lv = active_char&.level || 1 %>
<% is_v2 = current_lv >= 10 %>

<% 
  if is_v2
    koyoi_container_style = "position: absolute; top: 290px; left: 50%; width: 750px !important; max-width: none !important; transform: translateX(-50%); pointer-events: none; z-index: 20;"
  else
    koyoi_container_style = "position: absolute; bottom: -60px; left: 50%; width: 320px; transform: translateX(-50%); pointer-events: none; z-index: 20;"
  end
%>

<%# --- 2. キャラクター画像コンテナ --- %>
<div style="<%= koyoi_container_style %>">
  <%= image_tag current_user.current_koyoi_image, 
                id: "koyoi-image", 
                style: "width: 100%; height: auto; display: block; transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);" %>
</div>

<%# --- 3. 吹き出し（独立配置） --- %>
<div id="koyoi-bubble" 
     style="position: fixed; 
            bottom: 125px; 
            left: 20px; 
            background: white; 
            padding: 6px 14px; 
            border-radius: 2rem; 
            border: 2.5px solid #333; 
            font-weight: 900; 
            font-size: 13px; 
            box-shadow: 3px 3px 0px #333; 
            display: none; 
            z-index: 9999; 
            white-space: nowrap; 
            opacity: 1; 
            pointer-events: none;">
</div>

<script>
  window.jumpKoyoi = null;
  window.jumpKoyoi = function() {
    const img = document.getElementById('koyoi-image');
    if (!img) return;

    setTimeout(() => {
      img.style.transform = "translateY(-10px)";
      
      setTimeout(() => { 
        img.style.transform = "translateY(0)"; 
      }, 200);
    }, 300); 
  };

  window.showKoyoiTalk = function(text) {
    const bubble = document.getElementById('koyoi-bubble');
    if (!bubble) return;
    if (window.koyoiTimer) clearTimeout(window.koyoiTimer);
    bubble.innerText = text;
    bubble.style.display = "block";
    bubble.style.opacity = "1";
    window.koyoiTimer = setTimeout(() => { bubble.style.opacity = "0"; }, 5000);
  };
</script>