<%# 1. ボトムナビ本体 %>
<div id="walking-footer-container" style="position: fixed; bottom: 10px; left: 50%; width: 80%; max-width: 340px; height: 75px; transform: translateX(-50%); pointer-events: none; z-index: 9999;">
  
  <div style="width: 100%; height: 100%; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(20px); border-radius: 4rem; border: 2px solid white; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); pointer-events: auto;">
    
    <%# --- アルバムボタン（50px → 58pxへサイズアップ） --- %>
    <div id="btn-album" onclick="toggleAlbum()" style="width: 58px; height: 58px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0;">
      <i class="bi bi-image" style="font-size: 26px; color: #65C7A4;"></i>
    </div>

    <%# --- 中央のスペース確保用（カメラボタンの裏側） --- %>
    <div style="width: 60px;"></div>

    <%# --- マップボタン（50px → 58pxへサイズアップ） --- %>
    <div id="btn-map" onclick="toggleMap()" style="width: 58px; height: 58px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0;">
      <i class="bi bi-map" style="font-size: 26px; color: #65C7A4;"></i>
    </div>
  </div>

  <%# --- カメラ起動ボタン（サイズは前回のコンパクト版を維持） --- %>
  <div id="btn-camera-container" style="position: absolute; top: -30px; left: 50%; width: 90px; height: 90px; transform: translateX(-50%); z-index: 10000; pointer-events: auto;">
    <div onclick="openCamera()" style="width: 100%; height: 100%; background: white; border-radius: 50%; padding: 7px; box-shadow: 0 10px 20px rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: center; cursor: pointer;">
      <div style="width: 100%; height: 100%; background: #65C7A4; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
        <i class="bi bi-camera-fill" style="font-size: 36px; color: white;"></i>
      </div>
    </div>
  </div>
</div>

<%# 2. アルバム画面本体 %>
<%= render 'walkings/shared/walking_album' %>

<%# 3. お散歩マップ本体 %>
<%= render 'walkings/shared/walking_map' %>

<script>
  window.openCamera = function() {
    const input = document.getElementById('camera-input');
    if (input) input.click();
  };
</script>