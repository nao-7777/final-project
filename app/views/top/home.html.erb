<div class="min-h-screen w-full flex flex-col items-center justify-between p-6 pb-24 relative overflow-hidden">
  
  <%# --- 1. 左上のステータスエリア --- %>
  <%= render 'layouts/header' %>

  <%# --- 2. メインキャラ（中央） --- %>
  <div class="flex-1 flex items-center justify-center w-full z-10">
    <div class="relative w-64 h-64 md:w-80 md:h-80 animate-float">
      <%= image_tag "いらすとや狐.png", class: "w-full h-full object-contain filter drop-shadow-xl" %>
    </div>
  </div>

  <%# --- 3. お散歩ボタン --- %>
  <div class="w-full max-w-xs mb-12 z-20">
    <%= link_to new_walking_path, class: "group relative flex items-center justify-center w-full" do %>
      <%# ボタンの影と本体 %>
      <div class="absolute inset-0 bg-[#EE8095] rounded-full blur-md opacity-40 group-active:blur-sm transition-all"></div>
      <div class="relative w-full bg-[#EE8095] text-white text-xl font-black py-5 rounded-full shadow-lg border-b-4 border-[#D81B60] flex items-center justify-center gap-2 transition-transform active:translate-y-1 active:border-b-0">
        <span>お散歩する</span>
      </div>
    <% end %>
  </div>
</div>