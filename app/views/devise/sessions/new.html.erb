<style>
  body { margin: 0; }
  input { font-size: 16px !important; }
  /* フラッシュメッセージをカードの上に浮かせるためのスタイル */
  .flash-container {
    position: absolute;
    top: -10px; /* カードの少し上に出現 */
    left: 50%;
    transform: translateX(-50%) translateY(-100%);
    width: 90%;
    z-index: 50;
  }
</style>

<div class="min-h-[100dvh] w-full flex flex-col items-center justify-center bg-gradient-to-b from-[#ffe2ea] via-[#ffe2ea] via-20% to-[#97DBC1] bg-fixed px-6 overflow-hidden">
  
  <%# カードの親に relative を追加して、メッセージの基準点にする %>
  <div class="w-full max-w-md z-10 mt-20 mb-10 relative">

    <%# --- ここでメッセージを浮かせる --- %>
    <div class="flash-container">
      <%= render "devise/shared/flash_messages" %>
    </div>

    <div class="bg-white/70 p-8 md:p-10 rounded-[2.5rem] shadow-xl backdrop-blur-md"
         style="background-color: rgba(255, 255, 255, 0.75);">
      
      <h2 class="text-xl font-black text-center text-gray-800 mb-8 tracking-tighter">ログイン</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%# カード内からは削除（上の flash-container に移動したため） %>
        
        <div class="mb-4">
          <%= f.label :email, "メールアドレス", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
              required: true,
              class: "w-full px-4 py-2.5 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
        </div>

        <div class="mb-6">
          <%= f.label :password, "パスワード", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "パスワードを入力",
              required: true,
              class: "w-full px-4 py-2.5 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
        </div>

        <div class="text-center mb-6">
          <%= f.submit "ログインする", 
              class: "w-full max-w-[200px] mx-auto py-3 text-white font-black text-base rounded-full transition-all hover:opacity-90 shadow-md cursor-pointer block border-none",
              style: "background-color: #65C7A4;" %>
        </div>
      <% end %>

      <div class="text-center">
        <%= link_to "パスワードを忘れた場合", new_password_path(resource_name), class: "text-sm text-[#F7A7A2] hover:text-[#f38d87] underline" %>
      </div>

      <div class="border-t border-gray-300 my-6"></div>

      <div class="text-center">
        <p class="text-base text-gray-700 font-bold mb-6">初めての方はこちら</p>
        <%= link_to "アカウント作成", new_registration_path(resource_name),
            class: "w-full max-w-[180px] mx-auto py-3 text-[#65C7A4] font-bold text-sm rounded-full border-2 border-[#65C7A4] inline-block transition-all hover:bg-[#65C7A4]/10 text-decoration-none" %>
      </div>

    </div>
  </div>
</div>