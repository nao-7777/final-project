<style>
  /* 1. 全体の背景（デスクのような質感） */
  .log-index-body {
    background-color: #d1d9e6; 
    min-height: 100vh;
    padding: 40px 15px;
    font-family: 'Hiragino Maru Gothic ProN', sans-serif;
  }

  /* 2. ルーズリーフの紙 */
  .notebook-paper {
    background: #ffffff;
    max-width: 450px;
    margin: 0 auto;
    min-height: 80vh;
    position: relative;
    box-shadow: 8px 8px 20px rgba(0,0,0,0.1);
    border-radius: 2px;
    padding: 60px 25px 40px 70px; /* 左側に穴の余白 */
    /* 薄いドット方眼の背景 */
    background-image: radial-gradient(#e0e0e0 1px, transparent 1px);
    background-size: 25px 25px;
  }

  /* 3. 左側のバインダー穴 */
  .notebook-paper::before {
    content: '';
    position: absolute;
    left: 25px;
    top: 0;
    bottom: 0;
    width: 25px;
    background-image: radial-gradient(circle, #d1d9e6 7px, transparent 8px);
    background-size: 25px 45px; /* 穴の間隔 */
  }

  /* 4. 左側の赤い縦線（マージン線） */
  .notebook-paper::after {
    content: '';
    position: absolute;
    left: 60px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(255, 100, 100, 0.3);
  }

  .page-title {
    position: absolute;
    top: 20px;
    left: 80px;
    font-size: 18px;
    font-weight: 900;
    color: #555;
    border-bottom: 2px solid #65C7A4;
  }

  /* 5. ログ一行ずつのスタイル */
  .log-item {
    display: block;
    text-decoration: none;
    color: #444;
    margin-bottom: 35px;
    position: relative;
    border-bottom: 1px dashed #ccc;
    padding-bottom: 10px;
    transition: transform 0.2s;
  }

  .log-item:hover {
    transform: translateX(5px);
  }

  /* 日付（手書き風赤ペン） */
  .log-date-label {
    font-size: 12px;
    color: #EE8095;
    font-weight: bold;
    display: block;
    margin-bottom: 5px;
  }

  .log-main-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .log-steps {
    font-size: 22px;
    font-weight: 900;
    font-family: 'Courier New', monospace;
  }

  .log-steps small {
    font-size: 12px;
    margin-left: 2px;
  }

  .log-info-right {
    text-align: right;
  }

  .log-duration {
    font-size: 13px;
    color: #777;
  }

  .log-exp {
    font-size: 14px;
    font-weight: 800;
    color: #49B394;
  }

  /* ミッション達成スタンプ（クリア時のみ） */
  .clear-stamp {
    position: absolute;
    right: -5px;
    top: -15px;
    width: 45px;
    height: 45px;
    border: 2px solid #EE8095;
    border-radius: 50%;
    color: #EE8095;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 900;
    transform: rotate(15deg);
    opacity: 0.7;
    pointer-events: none;
  }

  .no-data-msg {
    text-align: center;
    margin-top: 100px;
    color: #aaa;
    font-style: italic;
  }
</style>

<div class="log-index-body">
  <div class="notebook-paper">
    <div class="page-title">お散歩ログ</div>

    <% if @dates.any? %>
      <% @dates.each do |data| %>
        <%# 日付をタップすると、その日のリスト(date_index)へ飛ぶ %>
        <%= link_to date_walking_logs_path(date: data[:date]), class: "log-item" do %>
          <span class="log-date-label"><%= data[:date].strftime("%Y / %m / %d") %></span>
          
          <div class="log-main-row">
            <div class="log-steps">
              <%= number_with_delimiter(data[:total_steps]) %><small>steps (Total)</small>
            </div>
            <div class="log-info-right">
              <div class="log-duration"><%= data[:total_duration] / 60 %> min</div>
              <div class="log-exp" style="font-size: 11px;">タップして詳細を表示</div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="no-data-msg"><p>まだ記録がありません。</p></div>
    <% end %>
  </div>
</div>